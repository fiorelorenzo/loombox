# loombox relay production env (copy to `.env`, chmod 600, never commit).
# The real .env lives only on the host; this file documents the variables.

# Postgres password for the compose-managed database (generate a strong random).
POSTGRES_PASSWORD=change-me

# Better Auth signing secret (generate: `openssl rand -base64 48`). Rotating it
# invalidates existing login sessions.
BETTER_AUTH_SECRET=change-me

# Public origin the relay is served on. Must match the registered OAuth callback
# host: Better Auth's GitHub callback is <RELAY_PUBLIC_URL>/api/auth/callback/github.
RELAY_PUBLIC_URL=https://relay.loombox.dev

# GitHub OAuth App credentials (Settings > Developer settings > OAuth Apps).
# Authorization callback URL must be exactly:
#   https://relay.loombox.dev/api/auth/callback/github
GITHUB_CLIENT_ID=change-me
GITHUB_CLIENT_SECRET=change-me

# Optional: Google OAuth (leave both unset to disable Google login; GitHub
# alone is enough to run). From a Google Cloud project's "APIs & Services >
# Credentials", an OAuth 2.0 Client ID of type "Web application", with
# Authorized redirect URI set to exactly:
#   https://relay.loombox.dev/api/auth/callback/google
# See docs/deploy-relay.md for the full walkthrough (consent screen, scopes).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional (#97): Redis fan-out, only needed when running more than one
# relay replica behind a load balancer. Leave unset for a single instance
# (the default) — it uses in-process fan-out instead. When set, also bring
# up the compose `redis` profile (docker compose --profile redis up -d).
# REDIS_URL=redis://redis:6379

# Nightly backup (#103, see docs/relay-backup.md). Encrypts the pg_dump at
# rest before it's shipped off-box - generate with: openssl rand -base64 32.
# Back this key up somewhere other than this .env: losing it makes every
# existing backup unrestorable, same as ENCRYPTION_KEY-class secrets.
RELAY_BACKUP_ENCRYPTION_KEY=change-me

# How many nightly backups relay-backup.sh keeps in ./backups before pruning
# the oldest (default 14 if unset).
# RELAY_BACKUP_RETENTION_COUNT=14
