# loombox resident node env (copy to loombox-node.env, chmod 600, never commit).
# Loaded by loombox-node.service.example via EnvironmentFile=. See
# packages/node/src/config.ts (loadNodeConfig's doc comment) for the exact
# precedence/validation rules this mirrors.

# The relay this node connects out to (ws:// for a local dev relay, wss://
# for the real one).
LOOMBOX_RELAY_URL=wss://relay.loombox.dev

# This node's stable identity, sent in the `initialize` handshake and shown
# in the web app's device/node list. Pick something that identifies the
# host, e.g. the hostname.
LOOMBOX_NODE_ID=devbox

# Optional: this device's id, separate from LOOMBOX_NODE_ID. Defaults to
# LOOMBOX_NODE_ID (a CLI-run node is a single device) - only set this if you
# need the two to differ.
# LOOMBOX_DEVICE_ID=

# This node's bearer token, authorizing it against the relay's Better Auth
# as a device of your account. Obtain it via the device-authorization flow
# (#387: the node prints a short code, you approve it once at
# https://app.loombox.dev/device, and it prints the token back) - never a
# browser-held session token pasted by hand. See README.md's "Get a device
# token" step. The config loader's env var for this is LOOMBOX_AUTH_TOKEN
# (not LOOMBOX_DEVICE_TOKEN) - same value, `authToken` is just the field's
# generic name predating the device-auth-specific flow that mints it.
LOOMBOX_AUTH_TOKEN=

# Optional: pin the account this node's sessions are scoped under. Leave
# unset and the node resolves it from LOOMBOX_AUTH_TOKEN itself via the
# relay (the same Better Auth resolution the web client uses) - the normal
# path; only set this to override.
# LOOMBOX_ACCOUNT_ID=

# Exactly one of LOOMBOX_RECOVERY_CODE / LOOMBOX_AMK is required, so the
# node can get at your account's E2E Account Master Key.
#
# LOOMBOX_RECOVERY_CODE is the intended path: the node bootstraps the AMK
# from the relay's escrow at startup (the same recovery-code crypto
# apps/web drives), the way you'd get it into a second real device. Get
# your account's Recovery Code from the web app (Settings > Recovery Code)
# the first time you set one up.
LOOMBOX_RECOVERY_CODE=

# LOOMBOX_AMK is a raw base64-encoded 256-bit key, only meant as an escape
# hatch for tests/advanced use - wins over LOOMBOX_RECOVERY_CODE if both are
# set. Leave unset on a normal deploy.
# LOOMBOX_AMK=

# Optional: extra execution targets beyond the always-available `local`
# one, as a JSON array of TargetDescriptor (see packages/protocol). Leave
# unset to expose only `local` (running sessions directly on this host).
# LOOMBOX_TARGETS=[]

# Optional: where this node's on-disk state (persisted identity keypair,
# and the fallback keyring store on a host with no OS keyring session - see
# packages/node/README.md "Secrets at rest") lives. Defaults to
# ~/.loombox/node.
# LOOMBOX_NODE_STATE_DIR=

# Required by the spawned Claude Code ACP agent itself (not read by
# @loombox/node directly, but inherited by the child process
# packages/providers/claude spawns via `npx -y
# @agentclientprotocol/claude-agent-acp`, which wraps the `claude` CLI). A
# non-interactive, long-lived credential - generate with
# `claude setup-token` on this host, not a browser-held session. `claude`
# itself must also be reachable on PATH for the service user (see
# README.md's prerequisites).
CLAUDE_CODE_OAUTH_TOKEN=
