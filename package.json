{
  "name": "loombox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "license:check": "license-checker-rseidelsohn --production --excludePrivatePackages --failOn 'AGPL-1.0;AGPL-1.0-only;AGPL-1.0-or-later;AGPL-3.0;AGPL-3.0-only;AGPL-3.0-or-later;GPL-1.0;GPL-1.0-only;GPL-1.0-or-later;GPL-2.0;GPL-2.0-only;GPL-2.0-or-later;GPL-3.0;GPL-3.0-only;GPL-3.0-or-later;SSPL-1.0'",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "e2e:v0": "tsx scripts/v0-e2e-harness.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@loombox/eslint-config": "workspace:*",
    "@loombox/node": "workspace:*",
    "@loombox/relay": "workspace:*",
    "@loombox/supervisor": "workspace:*",
    "@types/node": "^22.8.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.13.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
